# autodelovi.sale — Environment Variables
# Copy to .env.local for local development
# Set these in Vercel dashboard for production

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Security — generate with: openssl rand -hex 32
SCRAPE_API_SECRET=your_random_secret_here
CRON_SECRET=your_cron_secret_here

# Optional: Resend.com for price alert emails
RESEND_API_KEY=
ALERT_EMAIL_TO=alerts@example.com

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_APP_URL=http://localhost:3000

NODE_ENV=development

# Stripe (placeholder test keys — replace with real keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
NEXT_PUBLIC_APP_URL=http://localhost:3000
